{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": "../",
    "resolveJsonModule": true,
    "typeRoots": ["./node_modules/@types", "../node_modules/@types"],
    "skipLibCheck": true
  },
  "include": ["**/*.ts"]
}